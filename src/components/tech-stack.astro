---
import { Icon } from "astro-icon/components"
import { techList } from "@/lib/tech"
import { cn } from "@/lib/utils"

const filteredTech = techList.filter(
  (tech) => !["Supabase", "Neon"].includes(tech.name)
)
---

<section id="tech-stack" class="flex flex-col space-y-5 md:space-y-8">
  <h2
    class="text-sm font-medium tracking-widest text-muted-foreground uppercase"
  >
    Tech I Love Working With
  </h2>

  <div class="flex flex-wrap gap-2 md:gap-3">
    {
      filteredTech.map((tech) => (
        <button
          type="button"
          class={cn(
            "magnetic group relative flex items-center gap-1.5 rounded-lg border border-border bg-secondary/30 px-2.5 py-1.5 transition-all duration-300 hover:border-foreground/20 hover:bg-secondary/60 hover:shadow-sm focus:ring-2 focus:ring-foreground/30 focus:outline-none md:gap-2.5 md:rounded-xl md:py-2 md:pr-3 md:pl-3.5",
            tech.hover
          )}
          data-magnetic
          aria-label={`Technology: ${tech.name}`}
        >
          <Icon
            name={tech.icon}
            class={cn(
              "h-4 w-4 shrink-0 transition-transform duration-300 group-hover:scale-110 md:h-5 md:w-5",
              tech.color
            )}
            aria-hidden="true"
          />
          <span class="pointer-events-none text-xs font-medium tracking-tight text-foreground md:text-sm">
            {tech.name}
          </span>
        </button>
      ))
    }
  </div>
</section>

<script>
  // @ts-nocheck - Simple DOM interaction, no complex typing needed
  // Magnetic hover effect with cleanup and reduced motion support
  const magneticElements = document.querySelectorAll("[data-magnetic]")
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches

  if (!prefersReducedMotion) {
    magneticElements.forEach((element) => {
      const onMouseMove = (e) => {
        const rect = element.getBoundingClientRect()
        const centerX = rect.width / 2
        const centerY = rect.height / 2

        // Damped movement for smoother feel
        const moveX = (e.clientX - rect.left - centerX) * 0.15
        const moveY = (e.clientY - rect.top - centerY) * 0.15

        element.style.transform = `translate3d(${moveX}px, ${moveY}px, 0)`
      }

      const onMouseLeave = () => {
        element.style.transition = "transform 0.2s ease-out"
        element.style.transform = "translate3d(0, 0, 0)"

        // Clear transition after reset to avoid interfering with next hover
        setTimeout(() => {
          element.style.transition = ""
        }, 200)
      }

      element.addEventListener("mousemove", onMouseMove)
      element.addEventListener("mouseleave", onMouseLeave)

      // Store cleanup function for potential reuse
      element._magneticCleanup = () => {
        element.removeEventListener("mousemove", onMouseMove)
        element.removeEventListener("mouseleave", onMouseLeave)
        delete element._magneticCleanup
      }
    })

    // Cleanup on page unload to prevent memory leaks
    window.addEventListener("beforeunload", () => {
      magneticElements.forEach((el) => {
        if (el._magneticCleanup) el._magneticCleanup()
      })
    })
  }
</script>

<style>
  .magnetic {
    will-change: transform;
    cursor: pointer;
    transition: transform 0.15s ease-out;
  }

  /* Respect user preference for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .magnetic {
      transition: none !important;
      transform: none !important;
      will-change: auto;
    }
  }
</style>
